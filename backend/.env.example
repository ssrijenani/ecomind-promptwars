# Server
PORT=5000
NODE_ENV=development

# CORS - the URL where your frontend runs
FRONTEND_URL=http://localhost:5173

# Supabase (find these in your Supabase project settings -> API)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Note: AI tip generation now happens client-side via Puter.js
# (see frontend/.env.example) -- no Anthropic API key needed here.
